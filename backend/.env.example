# ── Optional ──────────────────────────────────────────────────────────────────
APP_NAME="AI Book Platform API"
APP_VERSION="1.0.0"
DEBUG=false

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
